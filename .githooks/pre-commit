#!/usr/bin/env sh
set -eu

files=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$files" ] && exit 0

for f in $files; do
  case "$f" in
    *.php|*.css|*.js|*.html|*.htm|*.sql|*.md|*.txt)
      [ -f "$f" ] || continue
      php -r '
$f=$argv[1];
$s=file_get_contents($f);
if ($s === false) { fwrite(STDERR, "Cannot read: $f\n"); exit(2); }
if (strncmp($s, "\xEF\xBB\xBF", 3) === 0) { fwrite(STDERR, "BOM detected: $f\n"); exit(3); }
if (strpos($s, "\xEF\xBF\xBD") !== false) { fwrite(STDERR, "Replacement char detected: $f\n"); exit(4); }
if (preg_match_all("/[\x{0400}-\x{04FF}]/u", $s, $m)) {
  foreach ($m[0] as $ch) {
    if (!preg_match("/[А-Яа-яЁё]/u", $ch)) {
      fwrite(STDERR, "Suspicious Cyrillic char in: $f\n");
      exit(5);
    }
  }
}
' "$f" || {
        echo "Commit blocked: encoding issue in $f" >&2
        echo "Fix file encoding to UTF-8 (without BOM)." >&2
        exit 1
      }
      ;;
  esac
done

exit 0